# Friendly titles override the page H1 in the sidebar (and only there — the
# page's own H1 is unaffected). Use them when the H1 is too long or when the
# old explicit nav title in mkdocs.yml diverged from the H1 (e.g. "DemoApp
# Reference" vs the page's "DemoApp" H1). Plain entries inherit the H1.
nav:
  - overview.md
  - Integration:
      - integration.md
      - viewer_contract_v1_8.md
      - DemoApp Reference: demoapp.md
  - Internals:
      - Architecture: architecture.md
      - capture_and_replay.md
  - Authoring:
      - admin_authoring_guide.md
      - model_authoring_guide.md
      - Marker Pipeline: marker_pipeline.md
      - demo_walkthrough.md
  - Reference:
      - Subscriber Materials Plan: subscriber_materials_plan.md
  - ...

# index.md is the auto-rendered home page (linked from the site title); it
# should be reachable but not duplicated in the sidebar. New "draft" docs you
# want deployed but hidden from the sidebar can be added here too.
not_in_nav: |
  index.md
